# ===== eMAC API — .env สำหรับ POC (https://poc.moph.go.th/emac) =====
# คัดลอกเป็น .env บน server แล้วแก้ค่า <...> ให้เรียบร้อย (index.ts โหลด dotenv ให้อัตโนมัติ)

NODE_ENV=production
PORT=3100
LOG_LEVEL=info

# ---- HTTP / reverse proxy ----
# nginx "ไม่ strip prefix" (proxy_pass ไม่มี / ท้าย) → backend mount ทุก route ใต้ /emac
# ทำให้ URL สะอาด: /emac/auth/..., /emac/api/v1/..., /emac/embed/... (api ชั้นเดียว)
HTTP_BASE_PATH=/emac
PUBLIC_BASE_URL=https://poc.moph.go.th/emac
TRUST_PROXY=true

# ---- Database (Postgres จาก docker-compose ของ emac) ----
# ใช้ port แยก 5442 กันชนกับ Postgres ตัวอื่นบน server (ตั้ง POSTGRES_PORT=5442 ด้วย)
DATABASE_URL=postgres://postgres:<STRONG_PASSWORD>@127.0.0.1:5442/drugallergy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<STRONG_PASSWORD>
POSTGRES_DB=drugallergy
POSTGRES_PORT=5442

# ---- Adapters (POC ใช้ mock auth + Postgres จริง) ----
AUTH_PROVIDER=mock
KEY_SERVICE=local
KEY_STORE=postgres
DATA_STORE=postgres
CONSENT_PROVIDER=mock
HIS_CONNECTOR=mock

# ---- Session JWT (ของระบบเรา) — เปลี่ยนเป็นค่า random ยาว ๆ ----
SESSION_JWT_SECRET=<CHANGE_ME_LONG_RANDOM_SECRET>
SESSION_JWT_TTL_SECONDS=900

# ---- ETL / rollout ----
RETRO_WINDOW_DAYS=30
HOSPCODE_ALLOWLIST=
