# ===== eMAC API — .env สำหรับ Production (https://emac.moph.go.th) =====
# คัดลอกเป็น .env บน server แล้วแก้ค่า <...> ให้เรียบร้อย (index.ts โหลด dotenv ให้อัตโนมัติ)
#
# ต่างจาก deploy/.env.production.example (POC) ตรงที่:
#   - โดเมนนี้เป็น domain เดี่ยวของ eMAC เอง (ไม่ได้แชร์กับ service อื่นใต้ path /emac)
#   - app จึงรันที่ "root" ของ domain → HTTP_BASE_PATH ปล่อยว่าง (ไม่ใช่ /emac)
#   - ถ้าต่อไปต้องย้าย domain/เปลี่ยน path อีก แก้แค่ค่าด้านล่างนี้ ไม่ต้องแก้โค้ด

NODE_ENV=production
PORT=3100
LOG_LEVEL=info

# ---- HTTP / reverse proxy ----
# root domain deploy → ปล่อย HTTP_BASE_PATH ว่าง (nginx proxy_pass /auth /api /embed ตรง ๆ ไม่มี prefix)
HTTP_BASE_PATH=
# URL สาธารณะเต็มของ service — ใช้สร้าง absolute URL (OIDC redirect, card QR, embed link)
PUBLIC_BASE_URL=https://emac.moph.go.th
TRUST_PROXY=true

# ---- Database (Postgres จาก docker-compose ของ emac) ----
DATABASE_URL=postgres://postgres:<STRONG_PASSWORD>@127.0.0.1:5442/drugallergy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<STRONG_PASSWORD>
POSTGRES_DB=drugallergy
POSTGRES_PORT=5442

# ---- Adapters ----
# POC ใช้ mock auth; production จริงต้องเปลี่ยนเป็น real (ต้องมี MOPH_OIDC_* ครบก่อน)
AUTH_PROVIDER=mock
KEY_SERVICE=local
KEY_STORE=postgres
DATA_STORE=postgres
CONSENT_PROVIDER=mock
HIS_CONNECTOR=mock

# ---- MOPH Provider ID (OIDC) — ใช้เมื่อ AUTH_PROVIDER=real ----
# Redirect URI ที่ต้องลงทะเบียนกับ MOPH: https://emac.moph.go.th/auth/callback
MOPH_OIDC_ISSUER=
MOPH_OIDC_CLIENT_ID=
MOPH_OIDC_CLIENT_SECRET=
MOPH_OIDC_REDIRECT_URI=https://emac.moph.go.th/auth/callback

# ---- Session JWT (ของระบบเรา) — เปลี่ยนเป็นค่า random ยาว ๆ ----
SESSION_JWT_SECRET=<CHANGE_ME_LONG_RANDOM_SECRET>
SESSION_JWT_TTL_SECONDS=900

# ---- ETL / rollout ----
RETRO_WINDOW_DAYS=30
HOSPCODE_ALLOWLIST=
