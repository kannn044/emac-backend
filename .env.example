# ---- App ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---- HTTP / Reverse proxy ----
# local dev: ปล่อยว่าง (รันที่ root)
# production: service อยู่หลัง nginx ของ domain ที่แชร์หลาย service
#   HTTP_BASE_PATH=/drugallergy
#   PUBLIC_BASE_URL=https://api-mophlink.moph.go.th/drugallergy
#   TRUST_PROXY=true
HTTP_BASE_PATH=
PUBLIC_BASE_URL=
TRUST_PROXY=false

# ---- Database (PostgreSQL) ----
# API เชื่อมต่อผ่าน DATABASE_URL (ต้องตรงกับ POSTGRES_* ที่ docker-compose ใช้สร้าง DB)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/drugallergy

# ค่าที่ docker-compose.yaml อ่านไปสร้าง container Postgres (ให้ตรงกับ DATABASE_URL ข้างบน)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=drugallergy
POSTGRES_PORT=5432

# ---- Adapter selection (mock | real) ----
# ในช่วงพัฒนา P0–P6 ใช้ mock; ต่อ sandbox จริงค่อยเปลี่ยนเป็น real
AUTH_PROVIDER=mock
KEY_SERVICE=local
# ที่เก็บ keypair: postgres (default) | memory
#   dev เฟส 1 (mock auth) ที่ยังไม่มี Postgres → ตั้ง KEY_STORE=memory รันได้ทันที
KEY_STORE=postgres
CONSENT_PROVIDER=mock
HIS_CONNECTOR=mock

# ---- MOPH Provider ID (OAuth2 Authorization Code) — ใช้เมื่อ AUTH_PROVIDER=real ----
# UAT: https://uat-provider.id.th | PRD: https://provider.id.th
MOPH_PROVIDER_BASE_URL=
MOPH_PROVIDER_CLIENT_ID=
MOPH_PROVIDER_CLIENT_SECRET=
# ต้องตรงเป๊ะกับที่ลงทะเบียนกับ Provider ID (exact match)
MOPH_PROVIDER_REDIRECT_URI=
# scope ที่ client ได้รับอนุมัติ (คั่นด้วย space)
MOPH_PROVIDER_SCOPE=cid name_th name_eng organization
# GET /auth/callback (backend) จะ redirect ต่อไปหน้านี้พร้อม ?code (ว่าง = ตอบ JSON แทน)
MOPH_PROVIDER_FRONTEND_CALLBACK_URL=

# ---- Third-party OAuth broker ----
# URL ที่อนุญาตให้ /auth/login?redirect_to=... เด้ง code กลับ (comma-separated, ว่าง = ปิด)
# entry เป็น origin (อนุญาตทุก path) หรือ URL เต็ม (path ต้องตรง) — บังคับ https ยกเว้น localhost
THIRD_PARTY_REDIRECT_ALLOWLIST=

# ---- Session JWT (ของระบบเรา) ----
SESSION_JWT_SECRET=dev-only-change-me
# access token หมดอายุ (วินาที) — 1800 = 30 นาที
SESSION_JWT_TTL_SECONDS=1800
# refresh token / เพดาน session (วินาที) — 43200 = 12 ชม. เกินนี้ต้อง login ใหม่
SESSION_REFRESH_TTL_SECONDS=43200

# ---- ETL ----
RETRO_WINDOW_DAYS=30

# ---- Roll-out: จำกัด tenant ช่วงนำร่อง (comma-separated hospcode 5 หลัก, ว่าง=ไม่จำกัด) ----
HOSPCODE_ALLOWLIST=

# ---- Drug allergy history query (DuckDB read_parquet) ----
# glob path ของไฟล์ parquet บน server (ว่าง = ปิด endpoint /api/v1/drugallergy/search)
DRUGALLERGY_PARQUET_GLOB=
# โควตา record ที่ดึงได้ต่อ client (hospcode) ต่อวัน — reset เที่ยงคืนเวลาไทย
DRUGALLERGY_DAILY_LIMIT=10000
# จำนวน CID สูงสุดต่อ 1 request
DRUGALLERGY_MAX_CIDS=5000
