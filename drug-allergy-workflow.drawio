        <!-- DATA ZONE -->
        <mxCell id="a_data" value="DATA / ANALYTICS ZONE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="40" y="40" width="360" height="360" as="geometry"/></mxCell>
        <mxCell id="a_hdc" value="HDC DuckDB (db.db)&#10;person / drug_opd / drug_ipd / diagnosis_ipd" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="70" y="80" width="300" height="50" as="geometry"/></mxCell>
        <mxCell id="a_p1" value="Pipeline [1] sjs-ten&#10;diagnosis_ipd L51% &#8594; admit list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="300" height="50" as="geometry"/></mxCell>
        <mxCell id="a_p2" value="Pipeline [2] sjs-ten-ipd-drug&#10;cross-hospital retro search (CID) + TMT + classify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="70" y="220" width="300" height="60" as="geometry"/></mxCell>
        <mxCell id="a_stg" value="Patient-level output (staging)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="70" y="310" width="300" height="50" as="geometry"/></mxCell>

        <!-- ETL -->
        <mxCell id="a_etl" value="ETL Loader (cronjob ทุก 24 ชม.)&#10;idempotent UPSERT — ไม่ทับ record ที่ verified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="440" y="200" width="280" height="60" as="geometry"/></mxCell>

        <!-- APP ZONE / Postgres -->
        <mxCell id="a_app" value="APPLICATION ZONE (PostgreSQL)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="760" y="40" width="370" height="360" as="geometry"/></mxCell>
        <mxCell id="a_t1" value="patient_drugallergy (ข้อมูลตั้งต้น)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="780" y="80" width="330" height="36" as="geometry"/></mxCell>
        <mxCell id="a_t2" value="provider_signing_key (public key + KMS handle)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="780" y="126" width="330" height="36" as="geometry"/></mxCell>
        <mxCell id="a_t3" value="allergy_verification (decision + signature)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="780" y="172" width="330" height="36" as="geometry"/></mxCell>
        <mxCell id="a_t4" value="allergy_card (signed, immutable)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="780" y="218" width="330" height="36" as="geometry"/></mxCell>
        <mxCell id="a_t5" value="allergy_consent / consent_request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="780" y="264" width="330" height="36" as="geometry"/></mxCell>
        <mxCell id="a_t6" value="rejected_records / verification_audit_log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="780" y="310" width="330" height="36" as="geometry"/></mxCell>

        <!-- API -->
        <mxCell id="a_api" value="API — Node + TypeScript + Express&#10;(stateless, Nginx + PM2 cluster, Linux)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="440" y="460" width="280" height="60" as="geometry"/></mxCell>

