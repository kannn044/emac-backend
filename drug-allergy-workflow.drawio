        <mxCell id="d_l1" value="รพ. ปลายทาง (HIS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="40" y="40" width="300" height="720" as="geometry"/></mxCell>
        <mxCell id="d_l2" value="Allergy API" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="360" y="40" width="320" height="720" as="geometry"/></mxCell>
        <mxCell id="d_l3" value="ผู้ป่วย (แอปหมอพร้อม)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="700" y="40" width="300" height="720" as="geometry"/></mxCell>

        <mxCell id="d_req" value="POST /consent-requests&#10;ขอดูประวัติแพ้ยาคนไข้" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="60" y="90" width="260" height="50" as="geometry"/></mxCell>
