        <mxCell id="ae7" value="verify JWT + api/info" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;" edge="1" parent="1" source="a_api" target="a_moph"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ae8" value="sign / keys" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;" edge="1" parent="1" source="a_api" target="a_kms"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ae9" value="REST (auth)" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="a_in" target="a_api"><mxGeometry relative="1" as="geometry"/></mxCell>
